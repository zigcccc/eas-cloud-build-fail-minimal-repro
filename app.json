      "expo-image",
      "expo-localization",
      "expo-tracking-transparency",
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "e16eba60-af50-4a61-9cc5-38618016efa2"
      }
    },
    "owner": "expo.app",
